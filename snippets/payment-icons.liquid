{% comment %}
  Payment Icons Snippet
  Display accepted payment methods
{% endcomment %}

<div class="payment-icons-container">
  <span class="payment-label">We Accept:</span>
  <div class="payment-icons">
    <div class="payment-icon" title="Visa">
      <svg viewBox="0 0 48 32" fill="currentColor">
        <rect width="48" height="32" rx="4" fill="#1434CB"/>
        <text x="24" y="20" text-anchor="middle" fill="white" font-weight="bold" font-size="12">VISA</text>
      </svg>
    </div>
    <div class="payment-icon" title="Mastercard">
      <svg viewBox="0 0 48 32" fill="currentColor">
        <rect width="48" height="32" rx="4" fill="#EB001B"/>
        <circle cx="19" cy="16" r="8" fill="#FF5F00"/>
        <circle cx="29" cy="16" r="8" fill="#FFA500"/>
      </svg>
    </div>
    <div class="payment-icon" title="PayPal">
      <svg viewBox="0 0 48 32" fill="currentColor">
        <rect width="48" height="32" rx="4" fill="#003087"/>
        <text x="24" y="20" text-anchor="middle" fill="#FFC439" font-weight="bold" font-size="10">PayPal</text>
      </svg>
    </div>
    <div class="payment-icon" title="Apple Pay">
      <svg viewBox="0 0 48 32" fill="currentColor">
        <rect width="48" height="32" rx="4" fill="#000"/>
        <text x="24" y="20" text-anchor="middle" fill="white" font-weight="bold" font-size="9">Apple Pay</text>
      </svg>
    </div>
    <div class="payment-icon" title="Google Pay">
      <svg viewBox="0 0 48 32" fill="currentColor">
        <rect width="48" height="32" rx="4" fill="white" stroke="#ddd" stroke-width="1"/>
        <text x="24" y="20" text-anchor="middle" fill="#000" font-weight="bold" font-size="8">Google Pay</text>
      </svg>
    </div>
    <div class="payment-icon" title="Shop Pay">
      <svg viewBox="0 0 48 32" fill="currentColor">
        <rect width="48" height="32" rx="4" fill="#96009600" stroke="#ddd" stroke-width="1"/>
        <text x="24" y="20" text-anchor="middle" fill="#333" font-weight="bold" font-size="8">Shop Pay</text>
      </svg>
    </div>
  </div>
</div>

<style>
  .payment-icons-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1.5rem 0;
    flex-wrap: wrap;
  }

  .payment-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .payment-icons {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .payment-icon {
    width: 50px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .payment-icon svg {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .payment-icons-container {
      gap: 0.5rem;
    }

    .payment-icon {
      width: 45px;
      height: 28px;
    }
  }
</style>
