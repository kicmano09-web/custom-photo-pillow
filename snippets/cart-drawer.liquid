{% comment %}
  Cart Drawer Snippet
  Slide-out cart with quantity controls and checkout
{% endcomment %}

<div id="cartDrawer" class="cart-drawer">
  <div class="cart-drawer-overlay" id="cartDrawerOverlay"></div>
  <div class="cart-drawer-content">
    <div class="cart-drawer-header">
      <h2 class="cart-drawer-title">Your Cart</h2>
      <button id="closeCartDrawer" class="cart-drawer-close" aria-label="Close cart drawer">✕</button>
    </div>

    <div id="cartDrawerItems" class="cart-drawer-items">
      <!-- Cart items will be loaded here -->
    </div>

    <div class="cart-drawer-footer">
      <div class="cart-summary">
        <div class="summary-row">
          <span>Subtotal:</span>
          <span id="cartSubtotal">$0.00</span>
        </div>
        <div class="summary-row">
          <span>Shipping:</span>
          <span id="cartShipping">Calculated at checkout</span>
        </div>
        <div class="summary-row summary-total">
          <span>Total:</span>
          <span id="cartTotal">$0.00</span>
        </div>
      </div>

      <a href="/checkout" class="button button--primary button--large">
        Proceed to Checkout
      </a>
      <button id="continueShopping" class="button button--secondary">
        Continue Shopping
      </button>
    </div>
  </div>
</div>

<style>
  .cart-drawer {
    display: none;
  }

  .cart-drawer.active {
    display: block;
  }

  .cart-drawer-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 999;
    animation: fadeIn 0.3s ease;
  }

  .cart-drawer-content {
    position: fixed;
    right: 0;
    top: 0;
    height: 100vh;
    width: 100%;
    max-width: 500px;
    background: #ffffff;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    animation: slideIn 0.3s ease;
    box-shadow: -2px 0 10px rgba(0, 0, 0, 0.1);
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideIn {
    from { transform: translateX(100%); }
    to { transform: translateX(0); }
  }

  .cart-drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .cart-drawer-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    color: #000;
  }

  .cart-drawer-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #666;
    transition: color 0.2s ease;
  }

  .cart-drawer-close:hover {
    color: #000;
  }

  .cart-drawer-items {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
  }

  .cart-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .cart-item-image {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 8px;
    background: #f8f8f8;
  }

  .cart-item-details {
    flex: 1;
  }

  .cart-item-title {
    font-weight: 600;
    color: #000;
    margin: 0 0 0.5rem 0;
  }

  .cart-item-price {
    font-size: 0.9rem;
    color: #666;
    margin: 0 0 0.75rem 0;
  }

  .cart-item-qty {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    width: fit-content;
  }

  .cart-item-qty button {
    width: 30px;
    height: 30px;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 1rem;
  }

  .cart-item-qty input {
    width: 40px;
    border: none;
    text-align: center;
    font-weight: 600;
  }

  .cart-item-remove {
    background: none;
    border: none;
    color: #d4a574;
    cursor: pointer;
    font-size: 0.875rem;
    text-decoration: underline;
    margin-top: 0.5rem;
  }

  .cart-empty {
    text-align: center;
    padding: 2rem;
    color: #666;
  }

  .cart-drawer-footer {
    padding: 1.5rem;
    border-top: 1px solid #e0e0e0;
  }

  .cart-summary {
    margin-bottom: 1.5rem;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 0.75rem;
  }

  .summary-total {
    font-size: 1.125rem;
    font-weight: 700;
    color: #000;
    padding-top: 0.75rem;
    border-top: 1px solid #e0e0e0;
  }

  .button {
    padding: 1rem;
    border: none;
    border-radius: 6px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    text-align: center;
    display: block;
    width: 100%;
    transition: all 0.3s ease;
  }

  .button--primary {
    background: #000;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.75rem;
  }

  .button--primary:hover {
    background: #d4a574;
  }

  .button--secondary {
    background: #f8f8f8;
    color: #000;
    border: 1px solid #e0e0e0;
  }

  .button--secondary:hover {
    background: #e8e8e8;
  }

  @media (max-width: 768px) {
    .cart-drawer-content {
      max-width: 100%;
    }
  }
</style>

<script src="{{ 'cart-drawer.js' | asset_url }}" defer></script>
