{% comment %}
  Footer Section with Links and Social Media
{% endcomment %}

<footer class="footer" data-section-id="{{ section.id }}">
  <div class="footer-container">
    <div class="footer-content">
      <div class="footer-column">
        <h4 class="footer-heading">About</h4>
        <ul class="footer-list">
          <li><a href="#">About Us</a></li>
          <li><a href="#">Our Story</a></li>
          <li><a href="#">Sustainability</a></li>
          <li><a href="#">Blog</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="footer-heading">Support</h4>
        <ul class="footer-list">
          <li><a href="#">Contact Us</a></li>
          <li><a href="#">Track Order</a></li>
          <li><a href="#">FAQ</a></li>
          <li><a href="#">Returns</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="footer-heading">Legal</h4>
        <ul class="footer-list">
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/terms-of-service">Terms of Service</a></li>
          <li><a href="#">Refund Policy</a></li>
          <li><a href="#">Shipping Policy</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="footer-heading">Follow</h4>
        <div class="social-links">
          <a href="#" class="social-link" aria-label="Instagram">📷</a>
          <a href="#" class="social-link" aria-label="Facebook">👍</a>
          <a href="#" class="social-link" aria-label="Pinterest">📌</a>
          <a href="#" class="social-link" aria-label="TikTok">🎵</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="copyright">&copy; 2024 Custom Photo Pillow. All rights reserved.</p>
      <div class="payment-methods">
        <span class="payment-icon">💳</span>
        <span class="payment-icon">🅰️</span>
        <span class="payment-icon">🅿️</span>
        <span class="payment-icon">🍎</span>
        <span class="payment-icon">🔵</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #1a1a1a;
    color: #ffffff;
    padding: 4rem 2rem 2rem;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #333;
  }

  .footer-heading {
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 0 1rem 0;
    color: #d4a574;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-list li {
    margin-bottom: 0.75rem;
  }

  .footer-list a {
    color: #bbb;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .footer-list a:hover {
    color: #d4a574;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    font-size: 1.5rem;
    transition: transform 0.3s ease;
    cursor: pointer;
  }

  .social-link:hover {
    transform: scale(1.2);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copyright {
    font-size: 0.85rem;
    color: #999;
    margin: 0;
  }

  .payment-methods {
    display: flex;
    gap: 0.75rem;
  }

  .payment-icon {
    font-size: 1.25rem;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .payment-icon:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 2rem 1rem;
    }

    .footer-content {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
