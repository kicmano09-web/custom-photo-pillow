{% comment %}
  Joke Generator Section
  Random joke fetcher using external API (JokeAPI)
  Displays jokes with category and rating system
{% endcomment %}

<section class="joke-generator-section">
  <div class="container">
    <div class="joke-generator-wrapper">
      <div class="joke-header">
        <h2 class="joke-title">{{ section.settings.title }}</h2>
        <p class="joke-subtitle">{{ section.settings.subtitle }}</p>
      </div>

      <div class="joke-container">
        <!-- Loading State -->
        <div id="jokeLoading" class="joke-loading" style="display: none;">
          <div class="spinner"></div>
          <p>Loading a joke...</p>
        </div>

        <!-- Joke Display -->
        <div id="jokeDisplay" class="joke-display">
          <div id="jokeContent" class="joke-content">
            <p id="jokeText" class="joke-text">Click "Get Joke" to start laughing!</p>
            <p id="jokeCategory" class="joke-category"></p>
          </div>

          <!-- Rating Section -->
          <div class="joke-rating">
            <span class="rating-label">Did you like it?</span>
            <div class="rating-buttons">
              <button id="thumbsUp" class="rating-btn rating-up" title="Thumbs Up">
                👍
              </button>
              <button id="thumbsDown" class="rating-btn rating-down" title="Thumbs Down">
                👎
              </button>
            </div>
          </div>
        </div>

        <!-- Error State -->
        <div id="jokeError" class="joke-error" style="display: none;">
          <p>⚠️ Couldn't fetch a joke. Please try again!</p>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="joke-actions">
        <button id="getJokeBtn" class="button button--primary button--large">
          {{ section.settings.button_text }}
        </button>
        <button id="shareJokeBtn" class="button button--secondary">
          Share Joke
        </button>
      </div>

      <!-- Stats -->
      <div class="joke-stats">
        <p>Jokes loaded: <span id="jokeCount">0</span> | Rating: <span id="jokeRating">0%</span></p>
      </div>
    </div>
  </div>
</section>

<style>
  .joke-generator-section {
    padding: 4rem 0;
    background: linear-gradient(135deg, #f8f8f8 0%, #ffffff 100%);
    margin: 2rem 0;
  }

  .joke-generator-wrapper {
    max-width: 600px;
    margin: 0 auto;
  }

  .joke-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .joke-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #000;
    margin-bottom: 0.5rem;
  }

  .joke-subtitle {
    font-size: 1.1rem;
    color: #666;
    margin: 0;
  }

  .joke-container {
    background: white;
    border: 2px solid #e0e0e0;
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .joke-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #e0e0e0;
    border-top: 4px solid #d4a574;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .joke-loading p {
    margin: 0;
    color: #666;
    font-size: 0.95rem;
  }

  .joke-display {
    width: 100%;
  }

  .joke-content {
    margin-bottom: 1.5rem;
  }

  .joke-text {
    font-size: 1.25rem;
    font-weight: 500;
    color: #000;
    line-height: 1.6;
    margin: 0 0 1rem 0;
    min-height: 80px;
    display: flex;
    align-items: center;
  }

  .joke-category {
    display: inline-block;
    background: #d4a574;
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0;
  }

  .joke-rating {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e0e0e0;
  }

  .rating-label {
    font-size: 0.9rem;
    color: #666;
    font-weight: 600;
  }

  .rating-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .rating-btn {
    width: 44px;
    height: 44px;
    border: 2px solid #e0e0e0;
    background: white;
    border-radius: 50%;
    font-size: 1.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rating-btn:hover {
    border-color: #d4a574;
    transform: scale(1.1);
  }

  .rating-btn.active {
    background: #d4a574;
    border-color: #d4a574;
    transform: scale(1.15);
  }

  .joke-error {
    background: #ffebee;
    color: #c62828;
    padding: 1.5rem;
    border-radius: 8px;
    text-align: center;
    font-weight: 500;
  }

  .joke-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .button {
    padding: 1rem 2rem;
    border: none;
    border-radius: 6px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    flex: 1;
  }

  .button--primary {
    background: #000;
    color: white;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .button--primary:hover {
    background: #d4a574;
  }

  .button--primary:active {
    transform: scale(0.98);
  }

  .button--secondary {
    background: #f8f8f8;
    color: #000;
    border: 2px solid #e0e0e0;
  }

  .button--secondary:hover {
    background: #e8e8e8;
    border-color: #d4a574;
  }

  .joke-stats {
    text-align: center;
    font-size: 0.85rem;
    color: #999;
  }

  .joke-stats span {
    font-weight: 600;
    color: #d4a574;
  }

  @media (max-width: 768px) {
    .joke-generator-section {
      padding: 2rem 0;
    }

    .joke-title {
      font-size: 1.75rem;
    }

    .joke-container {
      padding: 1.5rem;
    }

    .joke-actions {
      flex-direction: column;
    }

    .button {
      flex: unset;
      width: 100%;
    }
  }
</style>

<script src="{{ 'joke-generator.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Joke Generator",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Random Joke Generator"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Get a laugh delivered fresh to your screen"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Get a Joke"
    }
  ],
  "presets": [
    {
      "name": "Joke Generator"
    }
  ]
}
{% endschema %}